# Server
PORT=3000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/receipt_tracker

# JWT
JWT_SECRET=your_super_secret_key_here
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=another_secret_for_refresh
JWT_REFRESH_EXPIRES_IN=30d

# Cloudflare R2 (Image Storage)
R2_ACCOUNT_ID=your_cf_account_id
R2_ACCESS_KEY_ID=your_r2_access_key
R2_SECRET_ACCESS_KEY=your_r2_secret
R2_BUCKET_NAME=receipt-tracker-images
R2_PUBLIC_DOMAIN=https://images.yourdomain.com

# OCR Microservice
OCR_SERVICE_URL=http://localhost:8000

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://10.0.2.2:3000,https://yourdomain.com
